{
  "name": "nestx",
  "version": "1.0.0",
  "description": "Powerful NestJS project generator with batteries included.",
  "author": "Yohanes Senbeto",
  "license": "MIT",
  "private": false,
  "type": "commonjs",
  "bin": {
    "nestx": "dist/index.js"
  },
  "files": [
    "dist",
    "src/templates"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && copyfiles -u 1 \"src/templates/**/*\" dist && chmod +x dist/index.js",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nestjs",
    "nest",
    "cli",
    "generator",
    "scaffold",
    "starter",
    "template",
    "typescript",
    "backend",
    "api",
    "node",
    "prisma"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.1.0",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YohanesSenbeto/nestx-cli-joni.git"
  },
  "bugs": {
    "url": "https://github.com/YohanesSenbeto/nestx-cli-joni/issues"
  },
  "homepage": "https://github.com/YohanesSenbeto/nestx-cli-joni#readme"
}
